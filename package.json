{
  "name": "WeCareALOT",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "lucide-react": "^0.546.0",
      "next": "^16.1.1",
      "next-themes": "^0.4.6",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "@orpc/server": "^1.12.2",
      "@orpc/client": "^1.12.2",
      "@orpc/openapi": "^1.12.2",
      "@orpc/zod": "^1.12.2",
      "better-auth": "1.5.2",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.1.18"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "db:push": "turbo -F @WeCareALOT/db db:push",
    "db:studio": "turbo -F @WeCareALOT/db db:studio",
    "db:generate": "turbo -F @WeCareALOT/db db:generate",
    "db:migrate": "turbo -F @WeCareALOT/db db:migrate",
    "check": "biome check --write ."
  },
  "dependencies": {
    "@WeCareALOT/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@WeCareALOT/config": "workspace:*",
    "@biomejs/biome": "^2.2.0",
    "@types/node": "^22.13.14",
    "lefthook": "^2.0.13",
    "turbo": "^2.8.12",
    "typescript": "^5"
  },
  "packageManager": "bun@1.2.19"
}
